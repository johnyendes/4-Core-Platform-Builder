# X-Core Platform Environment Configuration
# Copy this file to .env and update with your actual values

# Brain API Configuration
BRAIN_API_ENABLED=true
BRAIN_API_BASE_URL=http://localhost:8000/api
BRAIN_API_KEY=your-brain-api-key-here

# Development Settings
DEBUG=true
LOG_LEVEL=INFO

# Platform Configuration
PLATFORM_NAME=X-Core Platform
PLATFORM_VERSION=1.0.0

# Database (if needed in future)
# DATABASE_URL=sqlite:///./xcore.db

# Cache Configuration (if needed)
# CACHE_ENABLED=false
# CACHE_TTL=3600

# Rate Limiting (if needed)
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_PERIOD=60